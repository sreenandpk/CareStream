# ==============================================================================
# CareStream Backend - Environment Variables Template
# Copy this file to .env and fill in your actual credentials.
# NEVER commit the real .env file to version control.
# ==============================================================================

# --- Django Security ---
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL Database ---
DB_NAME=carestream_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# --- Redis Configuration ---
REDIS_URL=redis://127.0.0.1:6379/1

# --- Email (SendGrid - Registrations) ---
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_HOST_USER=your_email@gmail.com

# --- Email (Gmail - Reliable OTPs) ---
EMAIL_HOST_PASSWORD=your_gmail_app_password_here

# --- CORS / Origins ---
# FRONTEND_URL=http://localhost:3000

# --- Automatic Admin Initialization ---
# These credentials will be used by 'python manage.py init_admin' on startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@carestream.com

# --- NGROK SETUP (For Webhook Testing) ---
# Paste your auth token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
