# ==============================================================================
# CareStream Frontend - Environment Variables Template
# Copy this file to .env or .env.local and fill in your actual values.
# ==============================================================================

# --- API Configuration ---
# The URL of your Django backend API
# Default for development: http://localhost:8000/api/
NEXT_PUBLIC_API_URL=http://localhost:8000/api/

# --- WebSocket Configuration ---
# The URL of your Django Channels status network
# Default for development: ws://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
